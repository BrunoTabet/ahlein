# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# local | staging | production
ENVIRONMENT=local

# Postgres (with pgvector). Local default matches docker-compose.
DATABASE_URL=postgresql://bot:bot@localhost:5432/clinicbot

# Redis — session + 24h window state
REDIS_URL=redis://localhost:6379/0

# Which LLM backend the booking loop uses: gemini | claude
LLM_PROVIDER=gemini

# Google Gemini (native audio for the future voice phase; strong Arabic; low cost)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# Anthropic (alternative provider — kept for the eval bake-off)
ANTHROPIC_API_KEY=sk-ant-...
CLASSIFIER_MODEL=claude-haiku-4-5
ESCALATION_MODEL=claude-sonnet-4-6

# Fernet key for encrypting per-tenant credentials at rest.
# Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# WhatsApp Cloud API webhook verification token (you choose this string;
# enter the same value in the Meta webhook config).
WHATSAPP_VERIFY_TOKEN=dev-verify-token

LOG_LEVEL=INFO
